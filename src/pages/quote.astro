---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteUrl = "https://sachhaymoingay.com";

function slugify(text = "") {
  return text
    .toString()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/đ/g, "d")
    .replace(/Đ/g, "D")
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

const quoteFiles = await Astro.glob("/content/quotes/*.md");

const quotes = quoteFiles
  .map((item) => {
    const fileSlug = item.file.split("/").pop()?.replace(".md", "") || "";
    const finalSlug = slugify(item.frontmatter.slug || item.frontmatter.title || item.frontmatter.quote || fileSlug);

    return {
      ...item.frontmatter,
      slug: finalSlug,
    };
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="Quote mỗi ngày | Sách Hay Mỗi Ngày">
  <main class="quote-page">
    <section class="quote-hero">
      <p class="eyebrow">QUOTE MỖI NGÀY</p>
      <h1>Những câu chữ đáng để suy ngẫm chậm hơn một chút.</h1>
      <p class="intro">Một nơi lưu lại những câu trích dẫn giúp bạn đọc sâu hơn, nghĩ rõ hơn và sống tỉnh táo hơn.</p>
    </section>

    <section class="quote-list">
      {quotes.map((quote) => (
        <article class="quote-card">
          {quote.image && (
            <a href={`/quote/${quote.slug}/`}>
              <img src={quote.image} alt={quote.quote} class="quote-img" />
            </a>
          )}

          <div class="quote-content">
            <h2>“{quote.quote}”</h2>

            {quote.author && <p class="quote-author">— {quote.author}</p>}

            <div class="quote-actions">
              {quote.affiliate && (
                <a class="buy-btn" href={quote.affiliate} target="_blank" rel="noopener noreferrer">
                  Xem sách / sản phẩm
                </a>
              )}

              <a
                class="share-btn"
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`${siteUrl}/quote/${quote.slug}/`)}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                Chia sẻ Facebook
              </a>
            </div>
          </div>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .quote-page {
    background: #f4eadb;
    color: #12241f;
    padding: 120px 6vw 80px;
  }

  .quote-hero {
    max-width: 1100px;
    margin-bottom: 72px;
  }

  .eyebrow {
    color: #b87a2c;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .quote-hero h1 {
    font-family: Georgia, serif;
    font-size: clamp(56px, 9vw, 140px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    max-width: 1100px;
    margin: 16px 0 24px;
  }

  .intro {
    max-width: 680px;
    font-size: 20px;
    line-height: 1.7;
    opacity: 0.75;
  }

  .quote-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
  }

  .quote-card {
    background: #fffaf1;
    border: 1px solid rgba(18, 36, 31, 0.12);
    padding: 24px;
  }

  .quote-img {
    width: 100%;
    display: block;
    margin-bottom: 24px;
  }

  .quote-content h2 {
    font-family: Georgia, serif;
    font-size: clamp(28px, 3vw, 44px);
    line-height: 1.18;
    margin: 0 0 16px;
  }

  .quote-author {
    opacity: 0.7;
    font-size: 18px;
  }

  .quote-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 24px;
  }

  .buy-btn,
  .share-btn {
    padding: 14px 20px;
    text-decoration: none;
    font-weight: 700;
  }

  .buy-btn {
    background: #153f34;
    color: #fffaf1;
  }

  .share-btn {
    border: 1px solid #153f34;
    color: #153f34;
  }
</style>
