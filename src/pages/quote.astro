---
import BaseLayout from "../layouts/BaseLayout.astro";

const quoteFiles = await Astro.glob("/content/quotes/*.md");

const quotes = quoteFiles
  .map((item) => ({
    ...item.frontmatter,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="Quote mỗi ngày | Sách Hay Mỗi Ngày">
  <main class="quote-page">
    <section class="quote-hero">
      <p class="eyebrow">QUOTE MỖI NGÀY</p>
      <h1>Những câu chữ đáng để suy ngẫm chậm hơn một chút.</h1>
      <p class="intro">
        Một nơi lưu lại những câu trích dẫn giúp bạn đọc sâu hơn, nghĩ rõ hơn và sống tỉnh táo hơn.
      </p>
    </section>

   <section class="quote-list">
  {quotes.map((quote) => (
    <article class="quote-card">
      {quote.image && (
        <a href={quote.affiliate || "#"} target="_blank" rel="noopener noreferrer">
          <img src={quote.image} alt={quote.quote} class="quote-img" />
        </a>
      )}

      <div class="quote-content">
        <p class="quote-text">“{quote.quote}”</p>
        {quote.author && <p class="quote-author">— {quote.author}</p>}

        {quote.affiliate && (
          <a class="buy-btn" href={quote.affiliate} target="_blank" rel="noopener noreferrer">
            Xem sách / sản phẩm
          </a>
        )}

        <button
          class="share-btn"
          data-quote={quote.quote}
          data-author={quote.author}
          data-affiliate={quote.affiliate}
          data-image={quote.image}
        >
          Chia sẻ quote
        </button>
      </div>
    </article>
  ))}
</section>
      ))}
    </section>
  </main>

<script>
  document.querySelectorAll(".share-btn").forEach((button) => {
    button.addEventListener("click", async () => {
      const quote = button.dataset.quote;
      const author = button.dataset.author || "Sách Hay Mỗi Ngày";
      const affiliate = button.dataset.affiliate || "https://sachhaymoingay.com/quote/";
      const image = button.dataset.image;

      const text = `“${quote}”\n— ${author}\n\n${affiliate}`;

      if (navigator.share) {
        await navigator.share({
          title: "Quote hay",
          text,
          url: affiliate,
        });
      } else {
        await navigator.clipboard.writeText(image ? `${text}\nẢnh: ${image}` : text);
        alert("Đã copy quote + link. Bạn có thể dán để chia sẻ.");
      }
    });
  });
</script>

</BaseLayout>

<style>
  .quote-page {
    background: #f4eadb;
    color: #12241f;
    padding: 120px 6vw 80px;
  }

  .quote-hero {
    max-width: 980px;
    margin-bottom: 64px;
  }

  .eyebrow {
    color: #b87a2c;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

.quote-hero h1 {
  font-family: Georgia, serif;
  font-size: clamp(56px, 9vw, 140px);
  line-height: 0.92;
  letter-spacing: -0.04em;
  max-width: 1100px;
  margin: 16px 0 24px;
}

  .intro {
    max-width: 680px;
    font-size: 20px;
    line-height: 1.7;
    opacity: 0.75;
  }

  .quote-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
  }

  .quote-card {
    background: #fffaf1;
    border: 1px solid rgba(18, 36, 31, 0.12);
    padding: 20px;
  }

  .quote-image {
    aspect-ratio: 1 / 1;
    background: #153f34;
    color: #fffaf1;
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .quote-image p {
    font-family: Georgia, serif;
    font-size: clamp(28px, 4vw, 46px);
    line-height: 1.18;
    margin: 0;
  }

  .quote-image span {
    opacity: 0.7;
    font-size: 16px;
  }

  .quote-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 18px;
  }

  .quote-author {
    margin: 0;
    opacity: 0.7;
  }

  .share-btn {
    background: #153f34;
    color: #fffaf1;
    padding: 12px 16px;
    text-decoration: none;
    font-weight: 700;
  }

  .share-btn:hover {
    opacity: 0.85;
  }
.quote-img {
  width: 100%;
  display: block;
  margin-bottom: 18px;
}

.quote-content {
  padding: 8px 0 0;
}

.quote-text {
  font-family: Georgia, serif;
  font-size: 26px;
  line-height: 1.35;
  margin: 0 0 12px;
}

.buy-btn {
  display: inline-block;
  margin-top: 12px;
  background: #153f34;
  color: #fffaf1;
  padding: 12px 16px;
  text-decoration: none;
  font-weight: 700;
}

.share-btn {
  margin-top: 12px;
  margin-left: 8px;
  background: transparent;
  border: 1px solid #153f34;
  color: #153f34;
  padding: 12px 16px;
  font-weight: 700;
  cursor: pointer;
}
</style>
