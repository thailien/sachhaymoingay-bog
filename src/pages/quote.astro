---
import BaseLayout from "../layouts/BaseLayout.astro";
const quoteFiles = await Astro.glob("/content/quotes/*.md");

const quotes = quoteFiles
  .map((item) => ({
    ...item.frontmatter,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="Quote mỗi ngày | Sách Hay Mỗi Ngày">
  <main class="section">
    <div class="container">
      <p>Quote mỗi ngày</p>

      <h1>Những câu chữ đáng để suy ngẫm chậm hơn một chút.</h1>

      <div>
        {quotes.map((quote) => (
          <article style="margin-bottom: 48px;">
            <blockquote
              style="font-size: 2rem; line-height: 1.5; font-weight: 600;"
            >
              “{quote.quote}”
            </blockquote>

            {quote.author && (
              <p style="opacity: 0.7; margin-top: 12px;">
                — {quote.author}
              </p>
            )}
          </article>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
