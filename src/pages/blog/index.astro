---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatPostDate, getAllPosts } from "../../lib/posts";

const posts = getAllPosts();
---

<BaseLayout
  title="Blog sách | Sách Hay Mỗi Ngày"
  description="Toàn bộ bài viết review, gợi ý và ghi chú đọc sách từ Sách Hay Mỗi Ngày."
>
  <main>
    <section class="page-hero compact">
      <p class="eyebrow">Blog</p>
      <h1>Toàn bộ bài viết</h1>
      <p>Gợi ý sách, ghi chú đọc, review và hướng dẫn chọn sách theo mục tiêu đọc.</p>
    </section>

    <section class="section blog-list">
      {
        posts.map((post) => (
          <article class="blog-row">
            {post.cover && <img src={post.cover} alt="" loading="lazy" />}
            <div>
              <p class="post-date">{formatPostDate(post.date)}</p>
              <h2><a href={`/blog/${post.slug}/`}>{post.title}</a></h2>
              <p>{post.description}</p>
              <a class="text-link" href={`/blog/${post.slug}/`}>Đọc tiếp</a>
            </div>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>
